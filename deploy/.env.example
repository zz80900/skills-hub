# Docker 镜像标签
APP_IMAGE_TAG=latest

# PostgreSQL 初始化配置
POSTGRES_DB=skills_lib
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 应用连接数据库的 SQLAlchemy URL
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/skills_lib

# 系统启动时自动确保存在的本地管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT 登录态配置
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=720

# Docker 部署时请在 deploy/.env 填写 AD 配置
# backend/.env 已被 .dockerignore 排除，不会进入容器

# AD 域认证总开关
# false: 仅本地账号认证
# true: 登录时先查本地用户，本地不存在时再走 AD Kerberos + LDAP
AD_ENABLED=false

# AD Kerberos 配置
# realm 例如: XGD.COM
# kdc 例如: 10.19.8.248
AD_REALM=
AD_KDC=

# AD LDAP 配置
# ldap url 例如: ldap://10.19.8.248:389
AD_LDAP_URL=

# 默认搜索根，支持文档中的简写格式
# 例如: OU=新国都集团|OU=支付硬件事业群|OU=技术中心
AD_BASE_DN=

# LDAP 在默认搜索根未命中时回退到的域根
# 不填时会按 AD_REALM 自动推导，例如 XGD.COM -> DC=xgd,DC=com
AD_DOMAIN_ROOT_DN=

# NetBIOS 域名，可用于 LDAP 服务账号绑定名拼接
# 例如: XGD
AD_NETBIOS_DOMAIN=

# LDAP 服务账号配置
# 仅用于目录查询，不参与用户 Kerberos 认证
AD_LDAP_BIND_USERNAME=
AD_LDAP_BIND_PASSWORD=

# 可选：若目录要求 UPN 绑定，则填写完整 principal
# 例如: ssc-skills@XGD.COM
AD_LDAP_BIND_PRINCIPAL=

# Kerberos 命令配置
# Linux 容器默认使用 kinit / kdestroy
AD_KINIT_COMMAND=kinit
AD_KDESTROY_COMMAND=kdestroy

# AD 调用超时时间，单位秒
AD_KERBEROS_TIMEOUT_SECONDS=15
AD_LDAP_TIMEOUT_SECONDS=15

# Nexus 原始 ZIP 仓库配置
NEXUS_RAW_BASE_URL=http://nexus.example.invalid:8081/repository/raw-repo/skills
NEXUS_USERNAME=
NEXUS_PASSWORD=

# 前端允许跨域访问的来源，多个值使用英文逗号分隔
CORS_ORIGINS=http://localhost:8000

# 首页远程技能源配置
SKILLS_API_BASE_URL=https://skills.sh
SKILLS_API_TIMEOUT_SECONDS=15

# 首页展示的 CLI 安装命令
CLI_INSTALL_COMMAND='npm install @xgd/ssc-skills -g --registry "http://nexus.example.invalid:8081/repository/npm-all"'
